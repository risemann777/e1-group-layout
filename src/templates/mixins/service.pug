include ../mixins/banner

mixin service(data)
  - list = data.list || null

  .service
    .service__container
      .service__list
        if list && list.length
          each item, index in list
            - name = item.name || `Name #${index+1}`
            - description = item.description || 'Lorem ipsum sit amet'
            - props = item.props || null
            - link = item.link || `usluga-detail.html#${index+1}`
            .service-card.service__item
              .service-card__info
                .service-card__name=name
                .service-card__description!=description
              .service-card__bottom
                a(href=link class="service-card__link") Подробнее
    .service__banner
      section(id="banner").section.section--animate
        .section__intersect.section__intersect--top
        .section__intersect.section__intersect--bottom
        +banner({
          title: ['Безопасность', 'превыше всего'],
          image: 'images/lift_service_root_banner_w1280.jpg',
          imageSources: [
            {
              media: '3840',
              src: "images/lift_service_root_banner_w4096.jpg"
            },
            {
              media: '2560',
              src: "images/lift_service_root_banner_w3840.jpg"
            },
            {
              media: '1920',
              src: "images/lift_service_root_banner_w2560.jpg"
            },
            {
              media: '1280',
              src: "images/lift_service_root_banner_w1920.jpg"
            }
          ],
          description: '<p>Лифты FRANZ строго соответствуют высоким стандартам производства домашних лифтов. Мы добросовестно относимся к каждому этапу, добиваясь надежного качества на высшем уровне, чтобы обеспечить безопасность клиентов.</p>',
          button: {
            name: 'Обсудить проект',
            toggle: 'modal',
            target: '#discussModal'
          }
        })
