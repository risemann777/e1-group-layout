include ../../mixins/form

footer.footer.layout__footer
  .footer__connect
    .footer__connect-info
      .footer__connect-cta Узнайте о сотрудничестве или задайте вопрос, заполнив форму.
      .footer__connect-contact
        span Или напишите нам на почту
        br
        a(href="mailto:e1group-info@mail.com") e1group-info@mail.com
    .footer__connect-form
      +form({
        modifiers: ["form--static"],
        common_errors: ["Похоже вы робот!"],
        theme: 'light',
        fields: [
          {
            type: 'text',
            name: 'name',
            label: 'Выше имя',
            placeholder: 'Имя / Огранизация',
            required: false
          },
          {
            type: 'tel',
            name: 'phone',
            label: 'Телефон',
            placeholder: 'Телефон',
            required: true
          },
          {
            type: 'text',
            name: 'email',
            label: 'E-mail',
            placeholder: 'E-mail',
            required: false,
            error: 'Обязательное поле'
          }
        ]
      })

  .footer__bottom
    .footer__bottom-info
      .footer__bottom-copyright Copyright © ООО «ДК РУ»
      .footer__bottom-address 125371, Россия, г. Москва, вн. тер. г. Муниципальный округ Покровское-Стрешнево, ш. Волоколамское, д. 116, офис 40
    .footer__bottom-links
      a(href="privacy.html") Политика конфиденциальности
      a(href="approve.html") Согласие на обработку персональных данных